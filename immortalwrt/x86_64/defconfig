# ========== 终极全硬件兼容驱动包 (v3.0 最终版) ==========

# --- Intel (全系列：千兆/万兆/25G/WiFi) ---
CONFIG_PACKAGE_kmod-ixgbe=y      # X520/X550 (10G)
CONFIG_PACKAGE_kmod-i40e=y       # X710/XXV710 (25G)
CONFIG_PACKAGE_kmod-igc=y        # I225/I226 (2.5G)
CONFIG_PACKAGE_kmod-e1000e=y     # I219/I211 (千兆)
CONFIG_PACKAGE_kmod-iwlwifi=y    # Intel AX200/210 WiFi

# --- Mellanox (40G/100G 顶级卡) ---
CONFIG_PACKAGE_kmod-mlx4-core=y  # CX3/CX3 Pro (40G)
CONFIG_PACKAGE_kmod-mlx4-en=y
CONFIG_PACKAGE_kmod-mlx5-core=y  # CX4/CX5/CX6 (25G/100G)

# --- Marvell Aquantia (电口万兆) ---
CONFIG_PACKAGE_kmod-atlantic=y   # AQC107/AQC113

# --- 服务器专用 (Broadcom/Solarflare) ---
CONFIG_PACKAGE_kmod-bnxt-en=y    # Broadcom 25G
CONFIG_PACKAGE_kmod-sfc=y         # Solarflare 10G

# --- Realtek (2.5G/USB) ---
CONFIG_PACKAGE_kmod-r8125=y      # PCIe 2.5G (RTL8125)
CONFIG_PACKAGE_kmod-r8169=y      # 常见 RTL 千兆
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y # USB 2.5G (RTL8156)
CONFIG_PACKAGE_kmod-usb-net-rtl8152-vendor=y

# --- 虚拟化与系统增强 ---
CONFIG_PACKAGE_kmod-vmxnet3=y    # ESXi 虚拟网卡
CONFIG_PACKAGE_kmod-virtio-net=y # PVE 虚拟网卡
CONFIG_PACKAGE_open-vm-tools=y   # ESXi Guest Tools

# --- 必带调试工具 ---
CONFIG_PACKAGE_ethtool=y         # 查看网卡速率/状态
CONFIG_PACKAGE_pciutils=y        # lspci 查看硬件
CONFIG_PACKAGE_usbutils=y         # lsusb 查看USB网卡
